rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ログイン（匿名ログインを含む）していれば、社内メンバーとして
    // 全コレクションの読み書きを許可するシンプルな構成です。
    // 匿名ログインでも「誰でもアプリを開けば書き込める」ため、
    // アプリのURLを社外に共有しないよう注意してください。
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
